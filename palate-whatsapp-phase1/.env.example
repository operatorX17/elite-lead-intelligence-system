APP_NAME=Palate WhatsApp Phase 1
ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/palate_whatsapp
INTERNAL_API_KEY=replace-with-a-long-random-internal-key
SESSION_TOKEN_PEPPER=replace-with-a-long-random-pepper
DASHBOARD_PASSWORD=replace-with-dashboard-password

WHATSAPP_PROVIDER=meta
DEMO_MODE=false
PUBLIC_BASE_URL=http://localhost:8000
PALATE_WHATSAPP_NUMBER=+919999999999
WHATSAPP_SESSION_TTL_MINUTES=1440

META_VERIFY_TOKEN=replace-with-meta-webhook-verify-token
META_APP_SECRET=replace-with-meta-app-secret
META_ACCESS_TOKEN=replace-with-meta-system-user-access-token
META_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
META_GRAPH_API_VERSION=v25.0
META_TIMEOUT_SECONDS=15
META_SEND_ENABLED=true
META_MOCK_MODE=false
META_SEND_MAX_ATTEMPTS=3
META_RETRY_BACKOFF_SECONDS=1.0

TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WEBHOOK_AUTH_ENABLED=true

RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

# Optional comma-separated CORS origins for the session-link caller.
CORS_ALLOW_ORIGINS=http://localhost:3000
